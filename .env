# Development default uses SQLite. For production use PostgreSQL, e.g.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/metas_cms?schema=public"
DATABASE_URL="file:./dev.db"

# Admin bootstrap credentials are created by prisma/seed.ts if no users exist.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="metas-admin-change-me"
ADMIN_EMAIL="admin@metasofsda.in"
ADMIN_SESSION_SECRET="replace-this-with-a-long-random-secret-of-at-least-32-characters"

# Encryption key for TOTP secrets at rest (min 32 characters)
ENCRYPTION_KEY="dev-local-encryption-key-change-in-prod"

# Public site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional email/CRM placeholders
FORMS_NOTIFICATION_EMAIL="principalcollege@metasofsda.in"
TURNSTILE_SECRET_KEY=""
