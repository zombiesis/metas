# Database (PostgreSQL required)
DATABASE_URL="postgresql://metas:metas@localhost:5432/metas_cms"

# Encryption key for TOTP secrets at rest (min 32 characters)
ENCRYPTION_KEY="change-this-to-a-random-32-char-string"

# Session signing secret (used for pending 2FA tokens)
SESSION_SECRET="change-this-to-a-random-secret"

# Application
NODE_ENV="development"
LOG_LEVEL="debug"

# Admin fallback credentials (dev only, ignored in production)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="metas-admin-change-me"
