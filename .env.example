# ─── Required ───────────────────────────────────────────
DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-this-to-a-64-char-random-string"
ENCRYPTION_KEY="change-this-to-a-32-char-random-string"
INTERNAL_API_SECRET="change-this-random-secret"

# ─── Application ────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
TRUST_PROXY="cloudflare"  # IMPORTANT: set to "cloudflare" in production (you have CF Enterprise)

# ─── Multi-Tenant ──────────────────────────────────────
# DEFAULT_BRANCH_ID=""  # set after running migrate-to-multitenant

# ─── Admin (dev only) ──────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="metas-admin-change-me"

# ─── Email (optional) ──────────────────────────────────
EMAIL_PROVIDER="console"  # console | sendgrid | ses | smtp
# SENDGRID_API_KEY=""
# AWS_REGION="ap-south-1"
EMAIL_FROM="noreply@metasofsda.in"
FORMS_NOTIFICATION_EMAIL=""

# ─── SMS (optional) ────────────────────────────────────
# SMS_PROVIDER="console"  # console | twilio | msg91
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""
# MSG91_AUTH_KEY=""

# ─── WhatsApp (optional) ───────────────────────────────
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""

# ─── Storage (optional — defaults to local filesystem) ─
# S3_BUCKET=""
# S3_REGION="ap-south-1"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""  # for MinIO/R2

# ─── Redis (optional — defaults to in-memory) ──────────
# REDIS_URL=""

# ─── AI (optional) ─────────────────────────────────────
# OPENAI_API_KEY=""

# ─── Data Retention ────────────────────────────────────
# DATA_RETENTION_DAYS="180"

# ─── Google Analytics (optional) ───────────────────────
# GA_MEASUREMENT_ID=""
